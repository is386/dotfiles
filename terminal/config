theme = Nord
background = #22262F
font-size = 16
font-family = Inconsolata
font-thicken = true
font-thicken-strength = 50
adjust-cell-height = 6
cursor-style = bar
cursor-style-blink = true
shell-integration = zsh

# Mac
macos-titlebar-proxy-icon = hidden
keybind = cmd+k=goto_split:top
keybind = cmd+j=goto_split:bottom
keybind = cmd+h=goto_split:left
keybind = cmd+l=goto_split:right
keybind = cmd+shift+k=resize_split:up,75
keybind = cmd+shift+j=resize_split:down,75
keybind = cmd+shift+h=resize_split:left,75
keybind = cmd+shift+l=resize_split:right,75

# Linux
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_surface
keybind = ctrl+d=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+one=goto_tab:1
keybind = ctrl+two=goto_tab:2
keybind = ctrl+three=goto_tab:3
keybind = ctrl+four=goto_tab:4
keybind = ctrl+five=goto_tab:5
keybind = ctrl+six=goto_tab:6
keybind = ctrl+seven=goto_tab:7
keybind = ctrl+eight=goto_tab:8
keybind = ctrl+nine=goto_tab:9
keybind = ctrl+k=goto_split:top
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+h=goto_split:left
keybind = ctrl+l=goto_split:right
keybind = ctrl+shift+k=resize_split:up,75
keybind = ctrl+shift+j=resize_split:down,75
keybind = ctrl+shift+h=resize_split:left,75
keybind = ctrl+shift+l=resize_split:right,75
