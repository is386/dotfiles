theme = Nord
background = #22262F
font-size = 16
font-family = Inconsolata
font-thicken = true
font-thicken-strength = 50
adjust-cell-height = 6
cursor-style = bar
cursor-style-blink = true
macos-titlebar-proxy-icon = hidden
shell-integration = zsh

keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+one=goto_tab:1
keybind = cmd+two=goto_tab:2
keybind = cmd+three=goto_tab:3
keybind = cmd+four=goto_tab:4
keybind = cmd+five=goto_tab:5
keybind = cmd+six=goto_tab:6
keybind = cmd+seven=goto_tab:7
keybind = cmd+eight=goto_tab:8
keybind = cmd+nine=goto_tab:9
keybind = cmd+up=goto_split:top
keybind = cmd+down=goto_split:bottom
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+shift+up=resize_split:up,50
keybind = cmd+shift+down=resize_split:down,50
keybind = cmd+shift+left=resize_split:left,50
keybind = cmd+shift+right=resize_split:right,50

keybind = ctrl+t=new_tab
keybind = ctrl+w=close_surface
keybind = ctrl+d=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+one=goto_tab:1
keybind = ctrl+two=goto_tab:2
keybind = ctrl+three=goto_tab:3
keybind = ctrl+four=goto_tab:4
keybind = ctrl+five=goto_tab:5
keybind = ctrl+six=goto_tab:6
keybind = ctrl+seven=goto_tab:7
keybind = ctrl+eight=goto_tab:8
keybind = ctrl+nine=goto_tab:9
keybind = ctrl+up=goto_split:top
keybind = ctrl+down=goto_split:bottom
keybind = ctrl+left=goto_split:left
keybind = ctrl+right=goto_split:right
keybind = ctrl+shift+up=resize_split:up,50
keybind = ctrl+shift+down=resize_split:down,50
keybind = ctrl+shift+left=resize_split:left,50
keybind = ctrl+shift+right=resize_split:right,50

